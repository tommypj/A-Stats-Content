{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "docs.astats.app" }],
      "destination": "https://a-stats.app/en/docs/:path*",
      "permanent": true
    }
  ]
}
